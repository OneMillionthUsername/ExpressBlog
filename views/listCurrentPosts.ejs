<% 
    pageTitle = 'Alle Blogposts - Sub specie aeternitatis';
    metaDescription = 'New posts on philosophy, tech, science and more.';
%>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="content-area">
                <div class="posts-header">
                    <% if (typeof activeTag !== 'undefined' && activeTag) { %>
                        <div class="active-tag-banner mb-2">
                            Tag: <strong><%= activeTag %></strong>
                            <a href="/blogpost/all" class="ml-2 btn btn-sm btn-outline-secondary">× Zurücksetzen</a>
                        </div>
                    <% } %>
                    <form id="tag-search-form" class="form-group mb-0" action="/blogpost/tag" method="GET">
                        <label class="sr-only" for="post-filter-input">Posts filtern</label>
                        <input id="post-filter-input" class="form-control post-filter-input" type="search" name="q" placeholder="Tag suchen (Enter zum Filtern)..." autocomplete="off">
                    </form>
                </div>
                <div id="blogPostsList">
                    <% if (typeof posts !== 'undefined' && Array.isArray(posts) && posts.length > 0) { %>
                        <% posts.forEach(function(post) { %>
                            <article class="blog-post-card">
                                <div class="post-meta">
                                    <span class="post-date"><%= new Date(post.created_at).toLocaleDateString('de-DE') %></span>
                                    <span class="post-author">von <%= post.author || 'Gast' %></span>
                                </div>
                                <h2 class="post-title">
                                    <% if (post.slug) { %>
                                        <a href="/blogpost/<%= post.slug %>" class="post-link"><%= post.title || 'Untitled' %></a>
                                    <% } else if (post.id !== undefined && post.id !== null) { %>
                                        <a href="/blogpost/id/<%= post.id %>" class="post-link"><%= post.title || 'Untitled' %></a>
                                    <% } else { %>
                                        <span class="post-link"><%= post.title || 'Untitled' %></span>
                                    <% } %>
                                </h2>
                                <% if (post.excerpt) { %><div class="post-excerpt"><%= post.excerpt %></div><% } %>
                                <div class="post-footer">
                                    <span class="post-views"><%= post.views || 0 %> Aufrufe</span>
                                </div>
                            </article>
                        <% }); %>
                    <% } else { %>
                        <div class="no-posts-card text-center py-5">
                            <h3 class="mb-2">Keine Posts vorhanden</h3>
                            <p class="text-muted lead mb-4">In dieser Kategorie wurden noch keine Blogposts veröffentlicht.</p>
                        </div>
                    <% } %>
                </div>
                <%- include('partials/pagination', { pagination: typeof pagination !== 'undefined' ? pagination : null }) %>
            </div>
        </div>
    </div>
    <div class="navigation text-center mt-4 mb-5">
        <a href="/" class="btn btn-outline-primary">Zur Startseite</a>
        <a href="/createPost" class="btn btn-outline-success ml-2 create-link hidden">Neuen Blogpost erstellen</a>
        <a href="/blogpost/archive" class="btn btn-outline-secondary ml-2">Archiv</a>
    </div>
</div>

<% locals.extraScripts = `
<script${typeof nonce !== 'undefined' ? ' nonce="' + String(nonce) + '"' : ''}>
    (function() {
        const form = document.getElementById('tag-search-form');
        const input = document.getElementById('post-filter-input');
        if (!form || !input) return;
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            const tag = input.value.trim();
            if (tag) {
                window.location.href = '/blogpost/tag/' + encodeURIComponent(tag);
            }
        });
    })();
</script>
`; %>
