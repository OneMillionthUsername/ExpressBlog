<%
    const isEdit = typeof card !== 'undefined' && card && card.id;
    pageTitle = isEdit ? 'Card bearbeiten - Sub specie aeternitatis' : 'Card erstellen - Sub specie aeternitatis';
    const action = (typeof formAction !== 'undefined' && formAction) ? formAction : '/cards/create';
%>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="content-area">
                <% if (typeof isAdmin === 'undefined' || !isAdmin) { %>
                    <div class="alert alert-warning">Nur Admins koennen Cards verwalten.</div>
                <% } else { %>
                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="alert alert-danger">Card konnte nicht gespeichert werden.</div>
                    <% } %>
                    <form method="POST" action="<%= action %>">
                        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <% } %>
                        <div class="form-group">
                            <label for="title">Titel</label>
                            <input class="form-control" id="title" name="title" required maxlength="255" value="<%= isEdit ? card.title : '' %>">
                        </div>
                        <div class="form-group">
                            <label for="subtitle">Untertitel</label>
                            <input class="form-control" id="subtitle" name="subtitle" maxlength="500" value="<%= isEdit && card.subtitle ? card.subtitle : '' %>">
                        </div>
                        <div class="form-group">
                            <label for="img_link">Bild URL</label>
                            <input class="form-control" id="img_link" name="img_link" required value="<%= isEdit ? card.img_link : '' %>">
                        </div>
                        <div class="form-group">
                            <label for="link">Link</label>
                            <input class="form-control" id="link" name="link" required value="<%= isEdit ? card.link : '' %>">
                        </div>
                        <div class="form-group form-check mt-3">
                            <input type="checkbox" class="form-check-input" id="published" name="published" value="on" <%= isEdit && card.published ? 'checked' : (!isEdit ? 'checked' : '') %>>
                            <label class="form-check-label" for="published">Veröffentlicht</label>
                        </div>
                        <div class="mt-3">
                            <button type="submit" class="btn btn-outline-primary"><%= isEdit ? 'Änderungen speichern' : 'Card speichern' %></button>
                            <a href="/cards/manage" class="btn btn-outline-secondary">Abbrechen</a>
                        </div>
                    </form>
                    <% if (isEdit) { %>
                        <form method="POST" action="/cards/<%= card.id %>/delete" class="mt-3">
                            <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <% } %>
                            <button type="submit" class="btn btn-outline-danger">Card löschen</button>
                        </form>
                    <% } %>
                <% } %>
            </div>
        </div>
    </div>
</div>
