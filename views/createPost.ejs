<% /* createPost.ejs - Blogpost erstellen/bearbeiten */ %>
<%
    pageTitle = 'Blogpost erstellen - Sub specie aeternitatis';
    useTinyMce = true;
    extraHead = (typeof extraHead === 'string' ? extraHead : '') + '<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism-okaidia.min.css">';
    if (typeof post !== 'undefined' && post) {
        extraHead += `<script id="server-post" type="application/json"${typeof nonce !== 'undefined' ? ' nonce="' + String(nonce) + '"' : ''}>${(function(obj){ try { const s = JSON.stringify(obj); return s.replace(/</g,'\\u003c').replace(/-->/g,'--\\u003e'); } catch(e){ return 'null'; } })(post)}<\/script>`;
    }
%>

<div class="container-fluid">
    <div class="row justify-content-center text-center">
        <div class="col-12">
            <div class="create-page-container">
                <!-- Admin-Schutz -->
                <div id="admin-required" class="content-area create-form-section <%= isAdmin ? 'hidden' : '' %>">
                    <div class="alert alert-warning text-center">
                        <h4>🔒 Zugriff verweigert</h4>
                        <p>Sie müssen sich als Administrator anmelden, um Blogposts erstellen zu können.</p>
                        <button data-action="show-admin-login" class="btn btn-primary">
                            👑 Als Admin anmelden
                        </button>
                        <a href="/" class="btn btn-outline-secondary ml-2">
                            Zur Startseite
                        </a>
                    </div>
                </div>
                <div id="create-content" class="content-area create-form-section <%= isAdmin ? '' : 'hidden' %>">
                    <% if (typeof formError !== 'undefined' && formError) { %>
                        <div class="alert alert-danger"><%= formError %></div>
                    <% } %>
                    <form id="blogPostForm" class="create-form" method="POST" action="<%= typeof formAction !== 'undefined' ? formAction : '/blogpost/create' %>">
                        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <% } %>
                        <% if (typeof post !== 'undefined' && post && post.id) { %>
                            <input type="hidden" name="id" value="<%= post.id %>">
                        <% } %>
                        <div class="form-group">
                            <label for="title" class="form-label">
                                <span class="label-icon">📝</span>
                                Titel
                            </label>
                            <input type="text" class="form-control create-input" id="title" name="title" 
                                   value="<%= (typeof post !== 'undefined' && post && post.title) ? post.title : '' %>" placeholder="Gib deinem Blogpost einen aussagekräftigen Titel..." required>
                            <small class="form-text text-muted">Ein guter Titel macht neugierig und fasst das Thema zusammen</small>
                        </div>
                        <div class="form-group">
                            <label for="content" class="form-label">
                                <span class="label-icon">✍️</span>
                                Inhalt
                            </label>
                            <div class="editor-toolbar mb-2">
                                <div class="toolbar-group">
                                    <span class="toolbar-label">📄 Vorlagen:</span>
                                    <button type="button" id="insert-template-blog-post" class="btn btn-sm btn-outline-secondary" data-template="blog-post">
                                        📝 Blog
                                    </button>
                                    <button type="button" id="insert-template-philosophy" class="btn btn-sm btn-outline-secondary" data-template="philosophy">
                                        🎓 Philosophie
                                    </button>
                                    <button type="button" id="insert-template-science" class="btn btn-sm btn-outline-secondary" data-template="science">
                                        🔬 Wissenschaft
                                    </button>
                                </div>
                                <div class="toolbar-group">
                                    <span class="toolbar-label">Kategorie:</span>
                                    <select name="category_id" required>
                                    <% categories.forEach(cat => { %>
                                        <option value="<%= cat.id %>" <%= post && post.category_id === cat.id ? 'selected' : '' %>><%= cat.name %></option>
                                    <% }) %>
                                    </select>
                                </div>
                                <div class="toolbar-group">
                                    <span class="toolbar-label">AI-Assistent:</span>
                                    <button type="button" id="ai-improve-btn" class="btn btn-sm btn-outline-primary ai-btn" data-action="improveText" title="Markierten Text oder ganzen Inhalt verbessern">
                                        ✨ Text verbessern
                                    </button>
                                    <button type="button" id="ai-title-btn" class="btn btn-sm btn-outline-primary ai-btn" data-action="generateTitleSuggestions" title="AI-generierte Titel-Vorschläge">
                                        💡 Titel vorschlagen
                                    </button>
                                    <button type="button" id="ai-tags-btn" class="btn btn-sm btn-outline-primary ai-btn" data-action="generateTags" title="Automatische Tag-Generierung">
                                        🏷️ Tags generieren
                                    </button>
                                    <button type="button" id="ai-summary-btn" class="btn btn-sm btn-outline-primary ai-btn" data-action="generateSummary" title="Zusammenfassung erstellen">
                                        📄 Zusammenfassen
                                    </button>
                                </div>
                                <div class="toolbar-group">
                                    <span class="toolbar-label">💾 Entwürfe:</span>
                                    <button type="button" id="save-draft-btn" class="btn btn-sm btn-outline-info" data-action="saveDraft">
                                        💾 Entwurf Speichern
                                    </button>
                                    <button type="button" id="load-draft-btn" class="btn btn-sm btn-outline-secondary" data-action="loadDraft">
                                        📂 Entwurf Laden
                                    </button>
                                    <button type="button" id="clear-draft-btn" class="btn btn-sm btn-outline-warning" data-action="clearDraft">
                                        🗑️ Löschen
                                    </button>
                                </div>
                                <div class="toolbar-group">
                                    <button type="button" id="show-api-key-setup" class="btn btn-sm btn-outline-success" data-action="showApiKeySetup" title="Google Gemini API-Schlüssel konfigurieren">
                                        ⚙️ AI Setup
                                    </button>
                                    <button type="button" id="show-tinymce-api-key-setup" class="btn btn-sm btn-outline-info" data-action="showTinyMceApiKeySetup" title="TinyMCE Editor API-Schlüssel konfigurieren">
                                        ✏️ Editor Setup
                                    </button>
                                </div>
                            </div>
                            <div class="editor-container">
                                <textarea class="form-control" id="content" name="content" lang="de" spellcheck="true" placeholder="Schreibe hier deinen Blogpost..."></textarea>
                            </div>
                            <small class="form-text text-muted">
                                Nutze die erweiterten Formatierungsoptionen für einen professionellen Text. 
                                <strong>Tipp:</strong> Verwende Strg+S zum Speichern und Strg+Z zum Rückgängigmachen.
                            </small>
                        </div>
                        <div class="form-group">
                            <label for="tags" class="form-label">
                                <span class="label-icon">🏷️</span>
                                Tags
                            </label>
                            <input type="text" class="form-control create-input" id="tags" name="tags" 
                                   value="<%= (typeof post !== 'undefined' && post && post.tags) ? (Array.isArray(post.tags) ? post.tags.join(', ') : post.tags) : '' %>" placeholder="z.B. Philosophie, Wissenschaft, Künstliche Intelligenz">
                            <small class="form-text text-muted">Trenne mehrere Tags mit Kommas.</small>
                            <div class="suggested-tags">
                                <span class="suggested-label">Beliebte Tags:</span>
                                <span class="tag-suggestion" data-action="add-tag" data-tag="Philosophie">Philosophie</span>
                                <span class="tag-suggestion" data-action="add-tag" data-tag="Wissenschaft">Wissenschaft</span>
                                <span class="tag-suggestion" data-action="add-tag" data-tag="Künstliche Intelligenz">Künstliche Intelligenz</span>
                                <span class="tag-suggestion" data-action="add-tag" data-tag="Ethik">Ethik</span>
                                <span class="tag-suggestion" data-action="add-tag" data-tag="Erkenntnistheorie">Erkenntnistheorie</span>
                            </div>
                        </div>
                        <div class="form-preview">
                            <h4 class="preview-title">
                                <span class="preview-icon">👀</span>
                                Vorschau
                            </h4>
                            <div id="preview-content" class="preview-box">
                                <p class="preview-placeholder">Die Vorschau wird hier angezeigt, sobald du schreibst...</p>
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="published" name="published"
                                    <%= (typeof post === 'undefined' || !post || post.published !== false) ? 'checked' : '' %>>
                                <label class="form-check-label" for="published">
                                    <strong>Veröffentlicht</strong>
                                    <small class="text-muted d-block">Deaktivieren, um den Post als Entwurf zu speichern</small>
                                </label>
                            </div>
                        </div>
                        <div class="form-actions text-center">
                            <button type="submit" class="btn btn-outline-primary main-submit-btn">
                                <span class="btn-icon">💾</span>
                                Speichern
                            </button>
                            <button type="button" id="reset-form-btn" class="btn btn-outline-secondary" data-action="resetForm">
                                <span class="btn-icon">🗑️</span>
                                Zurücksetzen
                            </button>
                            <button type="button" id="toggle-preview-btn" class="btn btn-outline-info" data-action="togglePreview">
                                <span class="btn-icon">👀</span>
                                Vorschau einblenden
                            </button>
                        </div>
                    </form>
                    <div id="responseMessage" class="response-message"></div>
                    <div class="navigation text-center mt-4 mb-5">
                        <a href="/" class="btn btn-outline-primary">Zurück zur Startseite</a>
                        <a href="/posts" class="btn btn-outline-secondary ml-2">Alle Blogposts</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
