<%
  pageTitle = 'Statistiken - Sub specie aeternitatis';
  metaDescription = '';
  metaRobots = 'noindex, nofollow';

  function fmtBytes(b) {
    if (b >= 1048576) return (b / 1048576).toFixed(1) + ' MB';
    if (b >= 1024) return (b / 1024).toFixed(1) + ' KB';
    return b + ' B';
  }

  function fmtMs(us) {
    return (us / 1000).toFixed(0);
  }

  function fmtNum(n) {
    return Number(n).toLocaleString('de-DE');
  }

  function latencyClass(us) {
    const ms = us / 1000;
    if (ms < 100) return 'stats-good';
    if (ms < 500) return 'stats-warn';
    return 'stats-bad';
  }

  function statusClass(code) {
    const c = String(code).charAt(0);
    if (c === '2') return 'stats-good';
    if (c === '3') return 'stats-info';
    if (c === '4') return 'stats-warn';
    if (c === '5') return 'stats-bad';
    return '';
  }
%>

<div class="container">
  <div class="content-area">
    <h2 class="mb-4">Statistiken</h2>

    <% if (!stats) { %>
      <div class="alert alert-danger">
        <h3 class="alert-heading">Report nicht verfügbar</h3>
        <p>Der GoAccess-Report konnte nicht geladen werden. Bitte prüfe, ob der Cron-Job korrekt läuft.</p>
      </div>
    <% } else { %>

      <%# ── GENERAL OVERVIEW ── %>
      <% const g = stats.general || {}; %>
      <div class="stats-meta">
        Zeitraum: <%= g.start_date || '–' %> – <%= g.end_date || g.start_date || '–' %>
        &nbsp;|&nbsp; Generiert: <%= g.date_time || '–' %>
      </div>

      <div class="stats-kpi-grid">
        <div class="stats-kpi-card stats-kpi--blue">
          <span class="stats-kpi-value"><%= fmtNum(g.total_requests || 0) %></span>
          <span class="stats-kpi-label">Requests (total)</span>
        </div>
        <div class="stats-kpi-card stats-kpi--green">
          <span class="stats-kpi-value"><%= fmtNum(g.valid_requests || 0) %></span>
          <span class="stats-kpi-label">Gültige Requests</span>
        </div>
        <div class="stats-kpi-card stats-kpi--gold">
          <span class="stats-kpi-value"><%= fmtNum(g.unique_visitors || 0) %></span>
          <span class="stats-kpi-label">Unique Visitors</span>
        </div>
        <div class="stats-kpi-card">
          <span class="stats-kpi-value"><%= fmtNum(g.unique_files || 0) %></span>
          <span class="stats-kpi-label">Unique Files</span>
        </div>
        <div class="stats-kpi-card stats-kpi--blue">
          <span class="stats-kpi-value"><%= fmtBytes(g.bandwidth || 0) %></span>
          <span class="stats-kpi-label">Bandwidth</span>
        </div>
        <div class="stats-kpi-card stats-kpi--red">
          <span class="stats-kpi-value"><%= fmtNum(g.unique_not_found || 0) %></span>
          <span class="stats-kpi-label">404 Not Found</span>
        </div>
      </div>

      <%# ── HELPER: render a section table ── %>
      <%
        function renderSection(title, section, opts) {
          opts = opts || {};
          const data = (section && section.data) || [];
          if (!data.length) return '';

          const showMethod = opts.showMethod || false;
          const showProtocol = opts.showProtocol || false;
          const labelHeader = opts.labelHeader || 'Pfad';
          const limit = opts.limit || 20;
          const isStatusCodes = opts.isStatusCodes || false;
          const rows = data.slice(0, limit);
          const maxHits = Math.max(...rows.map(r => r.hits ? r.hits.count : 0), 1);

          let html = '<div class="stats-section">';
          html += '<h3 class="stats-section-title">' + title + '</h3>';
          html += '<div class="stats-table-wrap"><table class="stats-table">';
          html += '<thead><tr>';
          html += '<th class="stats-th-label">' + labelHeader + '</th>';
          if (showMethod) html += '<th>Method</th>';
          if (showProtocol) html += '<th>Protocol</th>';
          html += '<th>Hits</th><th>%</th>';
          html += '<th>Visitors</th>';
          html += '<th>Bandwidth</th>';
          html += '<th>Avg (ms)</th>';
          html += '</tr></thead><tbody>';

          for (const row of rows) {
            const hits = row.hits ? row.hits.count : 0;
            const pct = row.hits ? parseFloat(row.hits.percent) : 0;
            const barWidth = Math.round((hits / maxHits) * 100);
            const lClass = latencyClass(row.avgts || 0);
            const rowClass = isStatusCodes ? statusClass(row.data) : '';

            html += '<tr' + (rowClass ? ' class="' + rowClass + '"' : '') + '>';
            html += '<td class="stats-td-label">';
            if (isStatusCodes) {
              html += '<span class="stats-status-dot ' + statusClass(row.data) + '"></span>';
            }
            html += (row.data || '–') + '</td>';
            if (showMethod) html += '<td>' + (row.method || '') + '</td>';
            if (showProtocol) html += '<td>' + (row.protocol || '') + '</td>';
            html += '<td>' + fmtNum(hits) + '</td>';
            html += '<td class="stats-td-bar"><span class="stats-bar" style="width:' + barWidth + '%"></span><span class="stats-bar-label">' + pct.toFixed(1) + '%</span></td>';
            html += '<td>' + fmtNum(row.visitors ? row.visitors.count : 0) + '</td>';
            html += '<td>' + fmtBytes(row.bytes ? row.bytes.count : 0) + '</td>';
            html += '<td class="' + lClass + '">' + fmtMs(row.avgts || 0) + ' ms</td>';
            html += '</tr>';
          }

          html += '</tbody></table></div>';
          if (data.length > limit) {
            html += '<p class="stats-truncated">' + (data.length - limit) + ' weitere Einträge nicht angezeigt</p>';
          }
          html += '</div>';
          return html;
        }
      %>

      <%- renderSection('Requests', stats.requests, { showMethod: true, showProtocol: true, labelHeader: 'URL' }) %>
      <%- renderSection('Besucher pro Tag', stats.visitors, { labelHeader: 'Datum' }) %>
      <%- renderSection('Statische Dateien', stats.static_requests, { showMethod: true, showProtocol: true, labelHeader: 'Datei' }) %>
      <%- renderSection('404 Not Found', stats.not_found, { showMethod: true, showProtocol: true, labelHeader: 'URL' }) %>
      <%- renderSection('Hosts', stats.hosts, { labelHeader: 'Host / IP' }) %>
      <%- renderSection('Betriebssysteme', stats.os, { labelHeader: 'OS' }) %>
      <%- renderSection('Browser', stats.browsers, { labelHeader: 'Browser' }) %>
      <%- renderSection('Besuchszeiten', stats.visit_time, { labelHeader: 'Stunde' }) %>
      <%- renderSection('Status-Codes', stats.status_codes, { labelHeader: 'Code', isStatusCodes: true }) %>
      <%- renderSection('Referring Sites', stats.referring_sites, { labelHeader: 'Referrer' }) %>
      <%- renderSection('Virtual Hosts', stats.vhosts, { labelHeader: 'VHost' }) %>

    <% } %>
  </div>
</div>
