<% if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) { %>
<nav class="pagination-nav mt-4" aria-label="Seitennavigation">
    <ul class="pagination justify-content-center flex-wrap">
        <li class="page-item <%= pagination.currentPage <= 1 ? 'disabled' : '' %>">
            <a class="page-link" href="<%= pagination.baseUrl %>?page=<%= pagination.currentPage - 1 %><%= pagination.extraParams || '' %>">‹</a>
        </li>
        <% for (let i = 1; i <= pagination.totalPages; i++) { %>
            <li class="page-item <%= i === pagination.currentPage ? 'active' : '' %>">
                <a class="page-link" href="<%= pagination.baseUrl %>?page=<%= i %><%= pagination.extraParams || '' %>"><%= i %></a>
            </li>
        <% } %>
        <li class="page-item <%= pagination.currentPage >= pagination.totalPages ? 'disabled' : '' %>">
            <a class="page-link" href="<%= pagination.baseUrl %>?page=<%= pagination.currentPage + 1 %><%= pagination.extraParams || '' %>">›</a>
        </li>
    </ul>
</nav>
<% } %>
